# --- Garmin Connect ---
# Used only on first run / when garmin_tokens/ cache is invalidated.
# After the first successful login, garmin_tokens/ holds an OAuth1 token that's
# good for ~1 year, so credentials sit idle most of the time.
GARMIN_EMAIL=
GARMIN_PASSWORD=

# --- Strava OAuth ---
# Get CLIENT_ID and CLIENT_SECRET from https://www.strava.com/settings/api
# Run reauth_strava.py once to populate the three token fields below.
CLIENT_ID=
CLIENT_SECRET=
ACCESS_TOKEN=
REFRESH_TOKEN=
EXPIRES_AT=0
