# Strava OAuth app credentials (https://www.strava.com/settings/api)
CLIENT_ID=
CLIENT_SECRET=

# Strava OAuth tokens (initial values; auto-refreshed and persisted by the app)
ACCESS_TOKEN=
REFRESH_TOKEN=
EXPIRES_AT=0

# Webhook verification token (any random string, must match Strava subscription)
VERIFY_TOKEN=strava_fixer_token

# Strava web session cookie (for GPS activity web form fallback)
# Get from browser: DevTools -> Application -> Cookies -> strava.com -> _strava4_session
STRAVA_SESSION_COOKIE=

# Railway API for auto-updating env vars after token refresh
RAILWAY_API_TOKEN=
RAILWAY_PROJECT_ID=
RAILWAY_SERVICE_ID=
RAILWAY_ENVIRONMENT_ID=
