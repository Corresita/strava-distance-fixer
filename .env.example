# --- Garmin Connect ---
# Used only on first run / when garmin_tokens/ cache is invalidated.
# After the first successful login, garmin_tokens/ holds an OAuth1 token that's
# good for ~1 year, so credentials sit idle most of the time.
GARMIN_EMAIL=
GARMIN_PASSWORD=

# --- Strava OAuth ---
# Get CLIENT_ID and CLIENT_SECRET from https://www.strava.com/settings/api
# Run reauth_strava.py once to populate the three token fields below.
CLIENT_ID=
CLIENT_SECRET=
ACCESS_TOKEN=
REFRESH_TOKEN=
EXPIRES_AT=0

# --- Strava web session ---
# Required for the crop/truncate step (the OAuth API doesn't expose it).
# Capture from a logged-in browser: DevTools → Application → Cookies →
# https://www.strava.com → `_strava4_session` → copy the Value column.
# The cookie lasts weeks to months; refresh it when sync starts failing
# with auth errors at the crop step.
STRAVA_SESSION_COOKIE=

# --- Railway env-var sync (optional, for deployed sync_server) ---
# When set, every Strava OAuth token refresh and every _strava4_session rotation
# is pushed back to Railway's project variables so the values survive container
# restarts. Without these, fresh containers fall back to whatever you originally
# put in the env vars.
#
# Get RAILWAY_API_TOKEN from https://railway.app/account/tokens (create a project
# token). Project / service / environment IDs are visible in your Railway URL or
# the project Settings page.
RAILWAY_API_TOKEN=
RAILWAY_PROJECT_ID=
RAILWAY_SERVICE_ID=
RAILWAY_ENVIRONMENT_ID=
